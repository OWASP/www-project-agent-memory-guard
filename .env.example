# Source-aware semantic evaluator
# Copy this file to `.env` and fill in your real key.

AMG_SOURCE_RISK_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-key-here

# Use any OpenRouter model slug you want.
AMG_SOURCE_RISK_MODEL=openai/gpt-4.1-mini

# Optional but recommended for OpenRouter analytics / attribution.
AMG_SOURCE_RISK_SITE_URL=https://your-app.example
AMG_SOURCE_RISK_APP_NAME=SourceAwareMemoryGuard

# Optional override. Leave commented for OpenRouter default.
# AMG_SOURCE_RISK_BASE_URL=https://openrouter.ai/api/v1
